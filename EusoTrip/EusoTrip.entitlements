<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.developer.weatherkit</key>
	<true/>
	<!--
	  Shared container for iOS ↔ Pulse Watch App. Used for shared
	  UserDefaults and file storage alongside WCSession, so HOS,
	  load, and auth state stay in sync across the two bundles.
	  Must match the Watch app's entitlement.
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.app.eusotrip</string>
	</array>
	<!--
	  APNs environment. 'development' is what Xcode injects for debug
	  builds; the App Store / TestFlight provisioning profile auto-
	  remaps this to 'production' at archive time, so a single value
	  here covers both sandboxes without a second entitlements file.
	-->
	<key>aps-environment</key>
	<string>development</string>
	<!--
	  Shared Keychain access group — paired with the watch entitlement
	  so both bundles can read/write the Esang auth token under the
	  same kSecAttrAccessGroup, removing WCSession as the single
	  pairing-transport SPOF.
	-->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.app.eusotrip.shared</string>
	</array>
	<!--
	  Sign in with Apple. The bundle ID is registered with the
	  "Sign in with Apple" capability in the Apple developer portal;
	  the iOS client uses ASAuthorizationAppleIDProvider to request
	  an identity token which the server verifies against Apple's
	  JWKS.
	-->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!--
	  Passkeys (WebAuthn) — the `webcredentials:` entry scopes
	  passkeys created on this device to `eusotrip.com` so iOS will
	  only release them to a verified Apple App Site Association
	  (AASA) at https://eusotrip.com/.well-known/apple-app-site-
	  association. The server's RP_ID must match.
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>webcredentials:eusotrip.com</string>
		<string>webcredentials:app.eusotrip.com</string>
	</array>
</dict>
</plist>
