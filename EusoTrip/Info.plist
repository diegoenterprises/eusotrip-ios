<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<!-- Custom URL scheme for password reset deep links + vendor OAuth callbacks
	     (eusotrip://reset?token=… , eusotrip://oauth/callback/<vendor>?code=…&state=…). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.app.eusotrip</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>eusotrip</string>
			</array>
		</dict>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<!-- HOS clock + geofence + ESANG voice + load lifecycle progress
		     all need to keep ticking when the wrist is the only screen
		     awake. Without `location` the geofence enter/exit events
		     never fire while the phone is locked; without `audio` the
		     ESANG voice session drops the moment the screen sleeps;
		     without `fetch` + `processing` the BGTaskScheduler stops
		     waking the app for the 5-min HOS poll. -->
		<string>location</string>
		<string>audio</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<!-- Identifiers BGTaskScheduler will allow when registered.
		     `com.eusotrip.hos.poll` powers the 5-min HOS dashboard
		     refresh; `com.eusotrip.outbox.drain` flushes the offline
		     mutation queue when reachability flaps positive. -->
		<string>com.eusotrip.hos.poll</string>
		<string>com.eusotrip.outbox.drain</string>
	</array>
	<!-- Always + WhenInUse so the geofence handler keeps firing when
	     the driver pockets the phone mid-route. The when-in-use string
	     stays as the always-permission toggle's parent description per
	     Apple's 2-step prompt flow. -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>EusoTrip uses your background location so geofence arrival, automatic HOS state changes, and ESANG smart-stop suggestions keep working when your phone is locked or in your pocket.</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Usage descriptions -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>EusoTrip uses your location to show route weather, traffic, and nearby loads, and to automatically advance your trip screens when you arrive at pickup or delivery.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>EusoTrip uses the microphone for ESANG voice commands so you can talk to your copilot hands-free.</string>
	<key>NSMotionUsageDescription</key>
	<string>EusoTrip uses motion data to auto-detect when you start and stop driving so your HOS clock and trip screens advance without a tap.</string>
	<key>NSNearbyInteractionUsageDescription</key>
	<string>EusoTrip uses Ultra-Wideband to help you dock your truck precisely at loading bays and to coordinate hazmat escort handoffs with nearby drivers.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>EusoTrip transcribes what you say to ESANG on-device so your copilot can answer and navigate the app for you.</string>
	<key>NSCameraUsageDescription</key>
	<string>EusoTrip uses your camera to scan dock-door markers for AR-guided back-in alignment, capture proof-of-delivery photos, and read BOL barcodes.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>EusoTrip lets you attach photos from your library to load documents (BOL, rate con, damage reports).</string>
	<!-- ActivityKit Live Activities — required for ShipperLoadActivityAttributes.
	     When YES, `Activity<…>.request(...)` succeeds; when NO/missing, every
	     request throws and the lock-screen card never appears. -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<!-- Live Activities can stay on the lock screen even when the app is
	     fully suspended; the system pushes new ContentState via APNs.
	     Required for the per-load activity to update during long routes. -->
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<!-- Continuity / Handoff activity types — every NSUserActivity the app
	     calls `becomeCurrent()` on must be declared here, otherwise iOS
	     silently drops the advertise. Mirrors the
	     `ShipperHandoffActivityType` enum in
	     `EusoTrip/Services/ShipperHandoffContinuity.swift`. -->
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.app.eusotrip.LoadDetailActivity</string>
		<string>com.app.eusotrip.PostLoadActivity</string>
		<string>com.app.eusotrip.SettlementActivity</string>
		<string>com.app.eusotrip.BidsActivity</string>
		<string>com.app.eusotrip.ControlTowerActivity</string>
	</array>
	<!-- HERE Maps OAuth + JS credentials. Inlined here because the
	     project sets GENERATE_INFOPLIST_FILE=NO + INFOPLIST_PREPROCESS=NO,
	     which means xcconfig $(VAR) substitution does NOT flow into a
	     literal Info.plist. The xcconfig + INFOPLIST_KEY_* settings are
	     kept in sync for fallback build paths but the runtime path
	     reads from this plist. Rotate credentials by updating both
	     files together. -->
	<key>HEREAccessKeyId</key>
	<string>aFi-kDtCV1dbeQjNR0SKWw</string>
	<key>HEREAccessKeySecret</key>
	<string>tu2LygcYLwnqBsPV0sgZ_PfFbZBquNoBrcwcKbaxJuGZIK48APnmLycnYKULfdLVcvBvz9tOpAbWoqIWcxtlNA</string>
	<key>HEREClientId</key>
	<string>A8wYxsmwZBEqBIud1Jmc</string>
	<key>HEREUserId</key>
	<string>HERE-7239406a-1b48-45b5-9964-fb81d7a73a7a</string>
	<key>HERETokenEndpointURL</key>
	<string>https://account.api.here.com/oauth2/token</string>
	<key>HEREJSApiKey</key>
	<string>9IdICMe90C28r5DOmEoXpRfnFRHnaXf8O8oP57bozkA</string>
</dict>
</plist>
